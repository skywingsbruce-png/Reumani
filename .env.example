# 复制本文件为 .env 并填入你自己的密钥。.env 已被 .gitignore 忽略，永不入库。
# Copy this file to .env and fill in your own keys. .env is gitignored and never committed.

DEEPSEEK_API_KEY=sk-your-deepseek-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# 可选：换生物医学向量/重排序模型（默认 all-MiniLM-L6-v2 / ms-marco-MiniLM-L-6-v2）
# SSC_EMBED_MODEL=NeuML/pubmedbert-base-embeddings
# SSC_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
